{
  "git": {
    "commit": true,
    "commitMessage": "chore: release v${version}",
    "requireCleanWorkingDir": true,
    "tag": true,
    "tagName": "${version}",
    "push": true
  },
  "github": {
    "release": true,
    "tokenRef": "GITHUB_TOKEN",
    "draft": true,
    "tagName": "${version}",
    "push": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "✨ Features"
          },
          {
            "type": "fix",
            "section": "🐛 Bug Fixes"
          },
          {
            "type": "perf",
            "section": "⚡️ Performance Improvements"
          },
          {
            "type": "revert",
            "section": "⏪️ Reverts"
          },
          {
            "type": "docs",
            "section": "📝 Documentation",
            "hidden": true
          },
          {
            "type": "chore",
            "section": "🔧 Chores",
            "hidden": true
          }
        ]
      }
    },
    "@release-it/bumper": {
      "out": {
        "file": "CITATION.cff",
        "path": "version",
        "type": "text/yaml"
      }
    }
  }
}
