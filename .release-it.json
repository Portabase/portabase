{
  "git": {
    "commit": true,
    "commitMessage": "chore: release v${version}",
    "requireCleanWorkingDir": true,
    "tag": true,
    "tagName": "${version}",
    "push": true
  },
  "github": {
    "release": true,
    "tokenRef": "GITHUB_TOKEN"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular"
    },
    "@release-it/bumper": {
      "files": ["package.json", "CITATION.cff"],
      "bumpFiles": [
        {
          "file": "CITATION.cff",
          "versionRegExp": "version:\\s*\"([0-9]+\\.[0-9]+\\.[0-9]+)\""
        },
        {
          "file": "package.json",
          "versionRegExp": "\"version\":\\s*\"([0-9]+\\.[0-9]+\\.[0-9]+)\""
        }
      ]
    }
  }
}
